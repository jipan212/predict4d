[app]

# App title
title = 4DPredictor

# Package name
package.name = predict4d

# Package domain
package.domain = org.irvan

# Source code folder
source.dir = .

# Include files
source.include_exts = py,kv,png,csv

# Version
version = 1.0

# Requirements
requirements = python3,kivy

# Orientation
orientation = portrait

# Fullscreen
fullscreen = 0

# Icon
icon.filename = logo.png

# Android API
android.api = 31
android.minapi = 21
